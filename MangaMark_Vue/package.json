{
  "name": "mangamark",
  "version": "2.5.2",
  "title": "MangaMark-Extension",
  "copyright": "Copyright © 2026 Quyen Truong",
  "author": "Quyen Truong",
  "description": "Mark your manga as read",
  "displayName": "Manga Mark",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "vue",
    "vite",
    "create-chrome-ext"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:nettruyen": "vitest --reporter=verbose --testNamePattern Nettruyen",
    "build:chrome": "cross-env NODE_ENV=production && vue-tsc --noEmit && vite build && npx gulp chrome",
    "build:firefox": "cross-env NODE_ENV=production && vue-tsc --noEmit && vite build --mode=firefox && npx gulp zipFirefox",
    "clean:firefox": "npx gulp firefox_clean",
    "preview": "vite preview",
    "release": "npx gulp release",
    "deleter": "npx gulp delete_release",
    "fmt": "prettier --write '**/*.{vue,js,json,css,scss,md}'"
  },
  "dependencies": {
    "clipboard": "^2.0.11",
    "minimatch": "^10.1.1",
    "sweetalert2": "^11.26.17",
    "vue": "^3.5.26",
    "webext-storage-cache": "^6.0.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@types/chrome": "^0.1.32",
    "@types/jsdom": "^27.0.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "cross-env": "^10.1.0",
    "execa": "^9.6.1",
    "gulp": "4.0.2",
    "gulp-clean": "^0.4.0",
    "gulp-json-editor": "^2.6.0",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-shell": "^0.8.0",
    "gulp-zip": "^6.1.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1",
    "xmlbuilder": "^15.1.1"
  }
}